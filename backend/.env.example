GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=interview_copilot

# Auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=10080

# Resend — https://resend.com (OTP emails). Without key, OTP prints in backend console (dev only).
RESEND_API_KEY=
EMAIL_FROM=Interview Copilot <onboarding@resend.dev>
# If Resend fails, log OTP in server logs (Railway → Deploy logs). Set false when email works.
OTP_LOG_ON_SEND_FAILURE=true

# API protection
GLOBAL_GEMINI_DAILY_CAP=40
GEMINI_SPEECH_CLEAN=false
MAX_INTERVIEWS_PER_USER_PER_DAY=1

# Optional
DEMO_MODE=false
RATE_LIMIT_ENABLED=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://ai-interview-co-pilot.netlify.app
