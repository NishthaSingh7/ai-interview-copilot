GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=interview_copilot

# Auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=10080

# Resend — https://resend.com/api-keys and https://resend.com/domains
RESEND_API_KEY=
EMAIL_FROM=Interview Copilot <onboarding@resend.dev>
# Required for test sender: your Resend account email (until domain is verified)
RESEND_ALLOWED_TEST_EMAIL=you@gmail.com
# Hybrid OTP (default on): email via Resend; on-screen code if email fails
OTP_EMAIL_FALLBACK_ENABLED=true

# API protection
GLOBAL_GEMINI_DAILY_CAP=40
GEMINI_SPEECH_CLEAN=false
MAX_INTERVIEWS_PER_USER_PER_DAY=1

# Optional
DEMO_MODE=false
RATE_LIMIT_ENABLED=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://ai-interview-co-pilot.netlify.app

# Local observability (OrbStack + observability/docker-compose.yml)
OBSERVABILITY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ai-interview-copilot-backend
OTEL_SERVICE_VERSION=0.1.0
OTEL_DEPLOYMENT_ENVIRONMENT=local
LOG_LEVEL=INFO

# Production — Grafana Cloud OTLP (set on Railway, not in local .env)
# OBSERVABILITY_ENABLED=true
# GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-REGION.grafana.net/otlp
# GRAFANA_OTLP_INSTANCE_ID=
# GRAFANA_OTLP_TOKEN=
# OTEL_DEPLOYMENT_ENVIRONMENT=production
